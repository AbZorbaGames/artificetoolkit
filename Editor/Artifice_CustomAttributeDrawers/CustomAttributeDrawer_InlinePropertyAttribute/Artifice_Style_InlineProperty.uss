.inline-property-main-container{
    margin: 2px;

    border-width: 1px;
    border-color: var(--unity-colors-default-border);
    border-radius: 3px;
}

.inline-property-header-container{
    border-bottom-width: 1px;
    border-color: var(--unity-colors-inspector_titlebar-border);
    border-radius: 3px;
    background-color: var(--unity-colors-inspector_titlebar-background);
}

.inline-property-header{
    padding: 5px;
}

.inline-property-children-container{
    padding: 3px;
    background-color: var(--unity-colors-box-background);
}

.inline-property-borderless{
    border-width: 0px;
}
